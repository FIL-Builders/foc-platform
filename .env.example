# Filecoin / FOC network
FILECOIN_NETWORK=filecoin_calibration
FILECOIN_CALIBRATION_RPC_URL=

# Platform root wallet / signer. Never commit real private keys.
PLATFORM_ROOT_ADDRESS=
PLATFORM_ROOT_PRIVATE_KEY=

# Coordinator signer. Prefer short-lived session keys for real deployments.
COORDINATOR_ADDRESS=
COORDINATOR_PRIVATE_KEY=

# Optional deployed contract address for local scripts.
FOC_PLATFORM_REGISTRY_ADDRESS=

# Operations hardening. Keep the default profile for local demos. Production
# validation requires KMS/signer references and rejects raw private key envs.
FOC_PLATFORM_OPS_PROFILE=demo
FOC_PLATFORM_ROOT_KMS_KEY_REF=
FOC_COORDINATOR_KMS_KEY_REF=
FOC_PLATFORM_ADMIN_AUTH_AUDIENCE=
FOC_PLATFORM_API_RATE_LIMIT_RPM=60
FOC_PLATFORM_API_TIMEOUT_MS=10000
FOC_COORDINATOR_UPLOAD_TIMEOUT_MS=120000
FOC_COORDINATOR_PROVIDER_TIMEOUT_MS=120000
FOC_COORDINATOR_MAX_RETRIES=3
FOC_COORDINATOR_RETRY_BACKOFF_MS=1000
FOC_RECONCILIATION_INTERVAL_SECONDS=300

# Cloudflare Worker demo public configuration. These values are safe to commit
# only when they contain public addresses, tx hashes, object ids, CIDs, or URLs.
FOC_PLATFORM_DEMO_GENERATED_AT=
FOC_PLATFORM_DEMO_MODE=
FOC_PLATFORM_DEMO_STATUS=
FOC_PLATFORM_DEMO_OBJECT_ID=
FOC_PLATFORM_DEMO_ACCOUNT_ID=
FOC_PLATFORM_DEMO_PROVIDER_ID=
FOC_PLATFORM_DEMO_DATASET_ID=
FOC_PLATFORM_DEMO_PIECE_ID=
FOC_PLATFORM_DEMO_PIECE_CID=
FOC_PLATFORM_DEMO_RETRIEVAL_URL=
FOC_PLATFORM_DEMO_UPLOAD_TX_HASH=
FOC_PLATFORM_DEMO_REGISTRY_TX_HASHES_JSON=

# Local development ports.
FOC_PLATFORM_API_PORT=8787
