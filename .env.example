# Filecoin / FOC network
FILECOIN_NETWORK=filecoin_calibration
FILECOIN_CALIBRATION_RPC_URL=

# Platform root wallet / signer. Never commit real private keys.
PLATFORM_ROOT_ADDRESS=
PLATFORM_ROOT_PRIVATE_KEY=

# Coordinator signer. Prefer short-lived session keys for real deployments.
COORDINATOR_ADDRESS=
COORDINATOR_PRIVATE_KEY=

# Optional deployed contract address for local scripts.
FOC_PLATFORM_REGISTRY_ADDRESS=

# Local development ports.
FOC_PLATFORM_API_PORT=8787
