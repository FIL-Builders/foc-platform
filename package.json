{
  "name": "@fil-builders/foc-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build:artifacts": "forge build && node scripts/generate-registry-artifacts.mjs && node scripts/generate-tokenhost-wrapper-artifacts.mjs",
    "build:contracts": "forge build",
    "build:tokenhost": "node scripts/generate-tokenhost-wrapper-artifacts.mjs",
    "demo:seed-calibration-fixtures": "node scripts/seed-calibration-registry-fixtures.mjs",
    "lint": "node scripts/check-workspace.mjs",
    "ops:smoke": "node scripts/run-ops-smoke.mjs",
    "ops:validate": "node scripts/validate-ops-config.mjs",
    "test": "pnpm test:node && pnpm test:contracts",
    "test:admin": "node --test test/admin-reconciliation.test.mjs test/platform-admin-api.test.mjs",
    "test:api": "node --test test/platform-api.test.mjs",
    "test:contracts": "forge test",
    "test:node": "node --test",
    "test:ops": "node --test test/ops-hardening.test.mjs",
    "test:spine": "node --test test/dev-upload-spine.test.mjs",
    "test:tokenhost": "node --test test/tokenhost-demo.test.mjs",
    "worker:dev": "npx wrangler dev --local",
    "worker:dry-run": "npx wrangler deploy --dry-run --outdir /tmp/foc-platform-worker-dry-run",
    "worker:types": "npx wrangler types src/worker/worker-configuration.d.ts && node scripts/trim-trailing-whitespace.mjs src/worker/worker-configuration.d.ts"
  },
  "dependencies": {
    "viem": "^2.54.1"
  }
}
