{
  "manifestVersion": "0.1.0",
  "kind": "foc-platform-tokenhost-wrapper",
  "mode": "handWrittenRegistryWrapper",
  "schema": {
    "path": "apps/tokenhost-foc-platform/schema.json",
    "thsVersion": "2025-12",
    "schemaVersion": "0.1.0",
    "appName": "FOC Platform Demo",
    "appSlug": "foc-platform-demo",
    "primaryCollection": "UploadRequest",
    "sha256": "0xc154006dba33464e815268cda1c896cb302b45ca24b7085ece8c73124f9918ed"
  },
  "builder": {
    "repoPath": "$TOKENHOST_BUILDER_DIR",
    "buildCommand": "TH_UPLOAD_RUNNER=remote TH_UPLOAD_PROVIDER=filecoin_onchain_cloud TH_UPLOAD_REMOTE_ENDPOINT_URL=/storage/tokenhost/upload TH_UPLOAD_REMOTE_STATUS_URL=/storage/tokenhost/upload/status pnpm --dir \"$TOKENHOST_BUILDER_DIR\" th build \"$FOC_PLATFORM_DIR/apps/tokenhost-foc-platform/schema.json\" --chain filecoin_calibration --tx-mode sponsored --relay-base-url /__tokenhost/relay --out /tmp/foc-platform-tokenhost-demo",
    "chain": "filecoin_calibration",
    "txMode": "sponsored",
    "expectedArtifacts": [
      "manifest.json",
      "schema.json",
      "compiled/App.json",
      "contracts/App.sol",
      "ui-site/",
      "netlify.toml",
      "netlify/functions/tokenhost-upload-start.mjs",
      "netlify/functions/tokenhost-upload-status.mjs",
      "netlify/functions/tokenhost-upload-worker-background.mjs",
      "NETLIFY-UPLOADS.md"
    ],
    "externalIssues": [
      {
        "issue": "tokenhost/tokenhost-builder#79",
        "title": "Add app.focPlatform schema and manifest extension",
        "status": "open",
        "impact": "FOC metadata lives in this wrapper config until the builder emits app.focPlatform manifest extensions."
      },
      {
        "issue": "tokenhost/tokenhost-builder#80",
        "title": "Support FOC Platform registry lifecycle generation or wrapper mode",
        "status": "open",
        "impact": "Generated CRUD must wrap the hand-written registry; it is not production-equivalent to section 6.7."
      },
      {
        "issue": "tokenhost/tokenhost-builder#81",
        "title": "Generate FOC Platform admin and reconciliation surfaces",
        "status": "open",
        "impact": "Admin and reconciliation views live in the wrapper read model until the builder emits generated object, usage, dataset, coordinator, and mismatch surfaces."
      },
      {
        "issue": "tokenhost/tokenhost-builder#82",
        "title": "Add FOC Platform receipt-aware upload runner path",
        "status": "open",
        "impact": "Upload runner output remains prototype/wrapper metadata until it can produce section 6.7-compatible receipts."
      }
    ]
  },
  "extensions": {
    "focPlatform": {
      "paymentMode": "platformWallet",
      "billingMode": "quotaOnly",
      "coordinatorMode": "hosted",
      "defaultCopies": 2,
      "allowCDN": true,
      "accountIdSource": "platformUserHash",
      "idempotency": "requiredPerAccount",
      "receiptMode": "compact",
      "datasetStrategy": "perAccountProviderClass",
      "contractMode": "handWrittenRegistry"
    }
  },
  "focPlatform": {
    "paymentMode": "platformWallet",
    "billingMode": "quotaOnly",
    "coordinatorMode": "hosted",
    "defaultCopies": 2,
    "allowCDN": true,
    "accountIdSource": "platformUserHash",
    "idempotency": "requiredPerAccount",
    "receiptMode": "compact",
    "datasetStrategy": "perAccountProviderClass",
    "contractMode": "handWrittenRegistry"
  },
  "registry": {
    "name": "FocPlatformRegistry",
    "artifactPath": "artifacts/contracts/FocPlatformRegistry.json",
    "sourceName": "contracts/FocPlatformRegistry.sol",
    "bytecodeSha256": "0x70a84ae9a3ec837fa12793aca9019cc989b3fc097416519b01760ff56dcc22fa",
    "deployedBytecodeSha256": "0x2c49443e7a9ebf3337453240e706df249d29f4f217ec948d6c10e9502a199d1f",
    "requiredFunctions": [
      "requestUpload",
      "startUpload",
      "finalizeUpload",
      "failUpload",
      "cancelUpload",
      "expireUpload",
      "getStorageObject",
      "getAccountUsage",
      "getCopyReceipts",
      "receiptPayer"
    ]
  },
  "platformApi": {
    "sourcePath": "src/api/platform-api.mjs",
    "routes": {
      "createUpload": [
        "POST /storage/upload-requests",
        "POST /storage/upload"
      ],
      "tokenHostUpload": "POST /storage/tokenhost/upload",
      "tokenHostUploadStatus": "GET /storage/tokenhost/upload/status",
      "uploadBytes": "POST /storage/uploads/:objectId/bytes",
      "uploadStatus": [
        "GET /storage/uploads/:objectId/status",
        "GET /storage/uploads/:objectId",
        "GET /storage/uploads/status?objectId=:objectId"
      ],
      "object": "GET /storage/objects/:objectId",
      "usage": [
        "GET /storage/usage/:accountId",
        "GET /usage"
      ]
    },
    "auth": {
      "subjectHeader": "x-platform-user-id",
      "walletHeader": "x-platform-wallet-address",
      "accountId": "derivedServerSideBytes32"
    }
  },
  "adminApi": {
    "sourcePath": "src/api/platform-admin-api.mjs",
    "projectionPath": "src/admin/reconciliation.mjs",
    "routes": {
      "dashboard": "GET /admin/storage/dashboard",
      "objects": "GET /admin/storage/objects",
      "object": "GET /admin/storage/objects/:objectId",
      "usage": "GET /admin/storage/usage",
      "datasets": "GET /admin/storage/datasets",
      "coordinators": "GET /admin/storage/coordinators",
      "reconciliation": "GET /admin/storage/reconciliation"
    },
    "auth": {
      "mode": "explicitAdminHook",
      "defaultHeader": "x-platform-admin-token"
    }
  },
  "tokenHostRuntime": {
    "uploadProvider": "filecoin_onchain_cloud",
    "uploadRunnerMode": "remote",
    "transactionMode": "sponsored",
    "generatedUploadEndpoint": "/storage/tokenhost/upload",
    "generatedUploadStatusEndpoint": "/storage/tokenhost/upload/status",
    "platformCreateUploadEndpoint": "/storage/upload-requests",
    "platformUploadEndpoint": "/storage/uploads/:objectId/bytes",
    "platformStatusEndpoint": "/storage/uploads/:objectId/status"
  },
  "screens": [
    {
      "id": "request",
      "label": "Upload request",
      "uses": [
        "POST /storage/upload-requests",
        "POST /storage/upload"
      ]
    },
    {
      "id": "status",
      "label": "Upload status",
      "uses": [
        "GET /storage/uploads/:objectId/status",
        "GET /storage/uploads/:objectId"
      ]
    },
    {
      "id": "object",
      "label": "Object receipt",
      "uses": [
        "GET /storage/objects/:objectId"
      ]
    },
    {
      "id": "usage",
      "label": "Account usage",
      "uses": [
        "GET /storage/usage/:accountId",
        "GET /usage"
      ]
    },
    {
      "id": "admin-objects",
      "label": "Admin object browser",
      "uses": [
        "GET /admin/storage/objects",
        "GET /admin/storage/objects/:objectId"
      ]
    },
    {
      "id": "admin-usage",
      "label": "Admin usage dashboard",
      "uses": [
        "GET /admin/storage/usage"
      ]
    },
    {
      "id": "admin-reconciliation",
      "label": "Admin reconciliation",
      "uses": [
        "GET /admin/storage/reconciliation"
      ]
    }
  ],
  "boundaries": [
    "Token Host generated CRUD is a UI/upload scaffold only.",
    "FocPlatformRegistry remains authoritative for lifecycle, receipts, usage, relayer accountability, and coordinator controls.",
    "Admin and reconciliation screens are read-only wrapper projections until Token Host Builder emits native FOC Platform admin surfaces.",
    "No generated artifact may include coordinator private keys or platform root secrets.",
    "Real Filecoin Calibration and Synapse execution remain gated by Phase 0 credentials/evidence."
  ],
  "configSha256": "0x148a88c6a38b26c8dfd138a31d2178d2611ce656ac452ded101d58878cba006a"
}
