    "buildCommand": "TH_UPLOAD_RUNNER=remote TH_UPLOAD_PROVIDER=filecoin_onchain_cloud TH_UPLOAD_REMOTE_ENDPOINT_URL=/storage/upload TH_UPLOAD_REMOTE_STATUS_URL=/storage/uploads/status pnpm th build /Users/michaelseiler/dev/fil-builders/foc-platform/apps/tokenhost-foc-platform/schema.json --chain filecoin_calibration --tx-mode sponsored --relay-base-url /__tokenhost/relay --out /tmp/foc-platform-tokenhost-demo",
